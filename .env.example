# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/whatahotel?schema=public"

# --- Phase 2: automated data collection ---

# Shared secret for the scheduled update endpoint. When set, requests to
# /api/cron/update-beaches must send `Authorization: Bearer <CRON_SECRET>`.
# Vercel Cron sends this automatically. Leave unset only for local dev.
CRON_SECRET=""

# USF/NOAA AFAI satellite provider (the real, free data source) is ON by
# default. It queries NOAA/AOML's CoastWatch ERDDAP for USF Alternative
# Floating Algae Index values near each beach. Set to "false" to disable.
SARGASSUM_AFAI_ENABLED="true"
# Override the ERDDAP griddap CSV endpoint if needed (default: 7-day AFAI).
SARGASSUM_AFAI_ERDDAP=""

# Optional custom JSON feed; when set it takes priority over the AFAI provider.
# Each record: { "destination": string, "riskScore"?: 0-100,
# "densityIndex"?: 0-1, "statusDescription"?: string, "notes"?: string }
SARGASSUM_FEED_URL=""
SARGASSUM_FEED_NAME="Public feed (USF/NOAA)"

# Set to "true" to enable the seasonal estimator as a last-resort fallback.
# Off by default so it never overrides real satellite/feed data.
SARGASSUM_USE_SEASONAL_MODEL="false"

# --- Admin authentication ---

# Password for the admin area (/admin, /api/admin). Required in production.
ADMIN_PASSWORD=""

# Long random string used to sign admin session cookies. Generate with:
#   openssl rand -base64 32
ADMIN_SESSION_SECRET=""
