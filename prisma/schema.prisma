// WhataHotel Beach Intelligence™ — Prisma schema
// Datasource: PostgreSQL. Higher riskScore = safer beach (less sargassum).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for serverless runtime queries.
  url       = env("DATABASE_URL")
  // Direct (unpooled) connection for schema push / migrations at build time.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
}

/// A monitored stretch of coastline (e.g. "Cancun Hotel Zone").
model BeachZone {
  id                String                 @id @default(cuid())
  name              String                 @unique
  country           String
  region            String?
  latitude          Float
  longitude         Float
  /// 0-100, higher = better beach conditions (less sargassum).
  riskScore         Int
  riskLevel         RiskLevel
  statusDescription String
  source            String
  notes             String?
  lastUpdated       DateTime               @default(now())
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  /// Early-warning flag: recent news/announcements indicate conditions worse
  /// than the satellite reading (does not change riskScore, which stays
  /// satellite-derived and auditable).
  newsFlag          Boolean                @default(false)
  /// One-line summary of the flag reason, surfaced to travelers/admins.
  newsSummary       String?
  newsCheckedAt     DateTime?

  hotels            Hotel[]
  conditions        HotelBeachCondition[]
  reports           BeachReport[]

  @@index([country])
  @@index([riskLevel])
}

/// A recent news item / official announcement about a beach zone, discovered
/// via news search and severity-classified by an LLM. Context only — never
/// changes the satellite riskScore.
model BeachReport {
  id          String     @id @default(cuid())
  beachZoneId String
  beachZone   BeachZone  @relation(fields: [beachZoneId], references: [id], onDelete: Cascade)
  headline    String
  url         String
  source      String
  publishedAt DateTime
  /// LLM-assessed severity of the sargassum situation described, or null when
  /// the item isn't about current conditions.
  severity    RiskLevel?
  /// Whether the LLM judged the item relevant to current sargassum conditions.
  relevant    Boolean    @default(true)
  /// One-line LLM summary.
  summary     String?
  createdAt   DateTime   @default(now())

  @@unique([beachZoneId, url])
  @@index([beachZoneId])
  @@index([publishedAt])
}

/// A beachfront hotel mapped to a single beach zone.
model Hotel {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  city          String
  country       String
  description    String?
  pricePerNight Int?
  rating        Float?
  imageUrl      String?

  beachZoneId   String
  beachZone     BeachZone            @relation(fields: [beachZoneId], references: [id], onDelete: Cascade)
  condition     HotelBeachCondition?

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([beachZoneId])
  @@index([city])
}

/// Denormalised snapshot of a hotel's current beach condition,
/// derived from its beach zone. Enables fast search/sort by beach score.
model HotelBeachCondition {
  id          String    @id @default(cuid())
  hotelId     String    @unique
  hotel       Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  beachZoneId String
  beachZone   BeachZone @relation(fields: [beachZoneId], references: [id], onDelete: Cascade)
  riskScore   Int
  riskLevel   RiskLevel
  lastUpdated DateTime  @default(now())

  @@index([beachZoneId])
  @@index([riskLevel])
}
